    "build:studio": "pnpm --filter studio build",
    "build:styleguide": "pnpm --filter styleguide build",
    "studio:dev": "pnpm --filter studio dev",
    "studio:build": "pnpm --filter studio build",
    "styleguide:dev": "pnpm --filter styleguide dev",
    "styleguide:build": "pnpm --filter styleguide build",
    "sync-printful": "node --env-file=.env.local scripts/sync-printful.mjs",
    "migrate-sanity": "node --env-file=.env.local scripts/migrate-to-sanity.mjs"
